<Window x:Class="test2.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Login"
        Height="600"
        Width="1000"
        WindowStartupLocation="CenterScreen"
        Background="#0F3A52">

    <Grid>

        <Grid.Background>
            <ImageBrush ImageSource="/hinhanh/background_lg.gif"
                        Stretch="UniformToFill"/>
        </Grid.Background>

        <Border Width="750"
                Height="420"
                CornerRadius="15"
                Background="White"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">

            <Grid>

                <!-- ❌ FIXED -->
                <Button Content="✕"
                        Width="35"
                        Height="35"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Margin="0,10,10,0"
                        Background="Transparent"
                        BorderThickness="0"
                        Click="Close_Click" Panel.ZIndex="2"/>

                <Grid>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="350"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- LEFT -->
                    <Border x:Name="LeftPanel"
                            Grid.Column="0"
                            CornerRadius="15,0,0,15">

                        <Border.RenderTransform>
                            <TranslateTransform x:Name="leftTransform"/>
                        </Border.RenderTransform>

                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#0EA5A4" Offset="0"/>
                                <GradientStop Color="#4F46E5" Offset="0.5"/>
                                <GradientStop Color="#9333EA" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>

                        <StackPanel VerticalAlignment="Center"
                                    HorizontalAlignment="Center">

                            <TextBlock x:Name="txtTitle"
                                       Text="Hello, Welcome !"
                                       TextAlignment="Center"
                                       FontSize="35"
                                       Foreground="White"
                                       FontWeight="Bold"/>

                            <TextBlock x:Name="txtDesc"
                                       Text="Don't have an account ?"
                                       TextAlignment="Center"
                                       FontSize="14"
                                       Foreground="White"
                                       Margin="0,10,0,20"/>

                            <Button Content="Register"
                                    x:Name="btnSwitch"
                                    Width="150"
                                    Height="47"
                                    Click="Switch_Click"
                                    Background="Transparent"
                                    BorderBrush="White"
                                    BorderThickness="2"
                                    Foreground="White"
                                    Cursor="Hand" FontWeight="Bold" FontSize="16">              

                                <Button.RenderTransform>
                                        <ScaleTransform x:Name="btnScale" ScaleX="1" ScaleY="1"/>
                                    </Button.RenderTransform>

                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                        <Border x:Name="bd"
                                            Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            CornerRadius="20"
                                            Padding="5">    

                                            <ContentPresenter HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"/>
                                            </Border>

                                            <ControlTemplate.Triggers>

                                                <!-- Hover -->
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="bd"
                                                    Property="Background"
                                                    Value="#33FFFFFF"/>
                                                </Trigger>

                                                <!-- Click (nhấn xuống) -->
                                                <Trigger Property="IsPressed" Value="True">
                                                    <Setter TargetName="bd"
                                                            Property="RenderTransform">
                                                        <Setter.Value>
                                                            <ScaleTransform ScaleX="0.95" ScaleY="0.95"/>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Trigger>

                                                <!-- Disable -->
                                                <Trigger Property="IsEnabled" Value="False">
                                                    <Setter TargetName="bd"
                                                        Property="Opacity"
                                                        Value="0.5"/>
                                                </Trigger>

                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>

                            </Button>
                        </StackPanel>

                    </Border>

                    <!-- RIGHT -->
                    <Grid x:Name="RightPanel"
                          Grid.Column="1"
                          Margin="40">

                        <Grid.RenderTransform>
                            <TranslateTransform x:Name="rightTransform"/>
                        </Grid.RenderTransform>

                        <StackPanel VerticalAlignment="Center">

                            <TextBlock x:Name="txtFormTitle"
                                       Text="Login"
                                       FontSize="35"
                                       FontWeight="Bold"
                                       Foreground="#0EA5A4"
                                       HorizontalAlignment="Center"
                                       Margin="0,0,0,20"/>

                            <TextBox Height="35" Margin="0,0,0,18" Text="Email"/>
                            <PasswordBox Height="35" Margin="0,0,0,20"/>

                            <Button Content="Submit"
                                    Height="40"
                                    Background="#14B8A6"
                                    Foreground="White"/>
                        </StackPanel>

                    </Grid>

                </Grid>

            </Grid>

        </Border>

    </Grid>
</Window>