<Window x:Class="test2.Views.Invoices.InvoiceWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Hóa đơn &amp; Thanh toán" Height="750" Width="1100"
        WindowStartupLocation="CenterScreen" Background="#F8F9FC">

    <Window.Resources>
        <SolidColorBrush x:Key="SidebarBrush" Color="#1A1D21"/>
        <SolidColorBrush x:Key="PrimaryBlue" Color="#4E73DF"/>

        <Style x:Key="CenterTextStyle" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="TextAlignment" Value="Center"/>
        </Style>

        <Style x:Key="MenuStyle" TargetType="ListBoxItem">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="bd" Padding="15,12" Background="Transparent" Margin="10,2">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource PrimaryBlue}"/>
                                <Setter TargetName="bd" Property="CornerRadius" Value="8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="#F8F9FC">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0" Background="{StaticResource SidebarBrush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="80"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="🚘" Foreground="White" Margin="0,-5,10,0" FontSize="29"/>
                <TextBlock Text="GARA AUTO" Foreground="White" FontSize="20" FontWeight="Bold"/>
            </StackPanel>

            <ListBox Grid.Row="1" Background="Transparent" BorderThickness="0" Margin="0,10">
                <ListBoxItem Style="{StaticResource MenuStyle}">
                    <TextBlock Text="📊 Dashboard" Foreground="White" Margin="15,0,0,0"/>
                </ListBoxItem>
                <ListBoxItem Style="{StaticResource MenuStyle}">
                    <TextBlock Text="👥 Khách hàng" Foreground="White" Margin="15,0,0,0"/>
                </ListBoxItem>
                <ListBoxItem Style="{StaticResource MenuStyle}">
                    <TextBlock Text="🚘 Xe" Foreground="White" Margin="15,0,0,0"/>
                </ListBoxItem>
                <ListBoxItem Style="{StaticResource MenuStyle}">
                    <TextBlock Text="🛠️ Dịch vụ" Foreground="White" Margin="15,0,0,0"/>
                </ListBoxItem>
                <ListBoxItem Style="{StaticResource MenuStyle}">
                    <TextBlock Text="📦 Phụ tùng" Foreground="White" Margin="15,0,0,0"/>
                </ListBoxItem>
                <ListBoxItem Style="{StaticResource MenuStyle}" IsSelected="True">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🧾" Foreground="White"/>
                        <TextBlock Text="Hóa đơn &amp; Thanh Toán" Foreground="White" Margin="15,0,0,0"/>
                    </StackPanel>
                </ListBoxItem>
            </ListBox>
        </Grid>

        <Grid Grid.Column="1" Margin="25">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="Hóa đơn &amp; Thanh toán" FontSize="26" FontWeight="Bold" Foreground="#333" Margin="0,0,0,25"/>

            <UniformGrid Grid.Row="1" Columns="3" Margin="0,0,0,25">
                <Border Background="White" Margin="0,0,15,0" CornerRadius="12" Padding="20" BorderBrush="#4E73DF" BorderThickness="1,1,1,5">
                    <StackPanel>
                        <TextBlock Text="TỔNG DOANH THU" FontSize="11" FontWeight="Bold" Foreground="#4E73DF"/>
                        <TextBlock Text="25.500.000đ" FontSize="20" FontWeight="Bold" Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>
                <Border Background="White" Margin="0,0,15,0" CornerRadius="12" Padding="20" BorderBrush="#1CC88A" BorderThickness="1,1,1,5">
                    <StackPanel>
                        <TextBlock Text="ĐÃ THANH TOÁN" FontSize="11" FontWeight="Bold" Foreground="#1CC88A"/>
                        <TextBlock Text="18 hóa đơn" FontSize="20" FontWeight="Bold" Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>
                <Border Background="White" CornerRadius="12" Padding="20" BorderBrush="#F6C23E" BorderThickness="1,1,1,5">
                    <StackPanel>
                        <TextBlock Text="CHỜ XỬ LÝ" FontSize="11" FontWeight="Bold" Foreground="#F6C23E"/>
                        <TextBlock Text="03 hóa đơn" FontSize="20" FontWeight="Bold" Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <Border Grid.Row="2" Background="White" CornerRadius="12" BorderBrush="#E3E6F0" BorderThickness="1" Padding="15" Margin="0,0,0,20">
                <StackPanel Orientation="Horizontal">
                    <StackPanel Margin="0,0,20,0">
                        <TextBlock Text="Mã phiếu sửa chữa:" Margin="0,0,0,5" FontWeight="SemiBold"/>
                        <TextBox x:Name="txtRepairID" Width="150" Height="30" VerticalContentAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,20,0">
                        <TextBlock Text="Tiền công (VNĐ):" Margin="0,0,0,5" FontWeight="SemiBold"/>
                        <TextBox x:Name="txtLabor" Width="150" Height="30" VerticalContentAlignment="Center"/>
                    </StackPanel>
                    <Button x:Name="btnSave" Content="Lưu &amp; Thanh toán" Click="btnSave_Click" 
                            Background="#1CC88A" Foreground="White" Width="150" Height="30" Margin="0,20,0,0" BorderThickness="0" FontWeight="Bold">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="5"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </StackPanel>
            </Border>

            <Border Grid.Row="3" Background="White" CornerRadius="12" BorderBrush="#E3E6F0" BorderThickness="1" Padding="10">
                <DataGrid x:Name="InvoiceDataGrid" AutoGenerateColumns="False" CanUserAddRows="False" HeadersVisibility="Column" GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#F1F1F1" Background="Transparent" BorderThickness="0" RowHeight="55">
                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Foreground" Value="#4E73DF"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                            <Setter Property="Padding" Value="15"/>
                            <Setter Property="HorizontalContentAlignment" Value="Center"/>
                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                            <Setter Property="BorderBrush" Value="#F1F1F1"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Mã HĐ" Binding="{Binding MaHD}" Width="80" ElementStyle="{StaticResource CenterTextStyle}"/>
                        <DataGridTextColumn Header="Khách hàng" Binding="{Binding TenKH}" Width="*" ElementStyle="{StaticResource CenterTextStyle}"/>
                        <DataGridTextColumn Header="Biển số" Binding="{Binding BienSo}" Width="120" ElementStyle="{StaticResource CenterTextStyle}"/>
                        <DataGridTextColumn Header="Tổng tiền" Binding="{Binding TongTien}" Width="140" ElementStyle="{StaticResource CenterTextStyle}"/>
                        <DataGridTemplateColumn Header="Trạng thái" Width="140">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Background="#D1FAE5" CornerRadius="10" Padding="10,4" HorizontalAlignment="Center">
                                        <TextBlock Text="Đã thanh toán" Foreground="#059669" FontSize="11" FontWeight="SemiBold"/>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Grid>
    </Grid>
</Window>