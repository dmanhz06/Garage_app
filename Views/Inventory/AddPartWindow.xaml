<Window x:Class="test2.Views.Inventory.AddPartWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Thêm phụ tùng" Height="450" Width="350" WindowStyle="None" 
        AllowsTransparency="True" Background="Transparent" WindowStartupLocation="CenterOwner">
    <Border Background="White" CornerRadius="15" BorderBrush="#4E73DF" BorderThickness="1">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Text="THÊM PHỤ TÙNG MỚI" FontWeight="Bold" Foreground="#4E73DF" HorizontalAlignment="Center" FontSize="20"/>

            <StackPanel Grid.Row="1" Margin="0,15">
                <TextBlock Text="Tên phụ tùng" Margin="0,5" Foreground="#666"/>
                <TextBox x:Name="txtAddPartName" Height="30" VerticalContentAlignment="Center" Padding="5,0" Margin="0,0,0,10"/>

                <TextBlock Text="Đơn vị tính" Margin="0,5" Foreground="#666"/>
                <TextBox x:Name="txtAddUnit" Height="30" VerticalContentAlignment="Center" Padding="5,0" Margin="0,0,0,10"/>

                <TextBlock Text="Giá nhập (đ)" Margin="0,5" Foreground="#666"/>
                <TextBox x:Name="txtAddImportPrice" Height="30" VerticalContentAlignment="Center" Padding="5,0" Margin="0,0,0,10"/>

                <TextBlock Text="Giá bán (đ)" Margin="0,5" Foreground="#666"/>
                <TextBox x:Name="txtAddPrice" Height="30" VerticalContentAlignment="Center" Padding="5,0" Margin="0,0,0,10"/>

                <TextBlock Text="Số lượng nhập" Margin="0,5" Foreground="#666"/>
                <TextBox x:Name="txtAddQuantity" Height="30" VerticalContentAlignment="Center" Padding="5,0"/>
            </StackPanel>

            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Hủy" Width="70" Height="30" Margin="0,0,10,0" Click="Cancel_Click"/>
                <Button Content="Lưu" Width="70" Height="30" Background="#4E73DF" Foreground="White" Click="Save_Click"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>