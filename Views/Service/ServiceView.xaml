<Window x:Class="test2.Views.Service.ServiceView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Quản Lý Dịch Vụ" Height="750" Width="1250"
        WindowStartupLocation="CenterScreen" FontFamily="Segoe UI">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <SolidColorBrush x:Key="SidebarBrush" Color="#1A1D21"/>
        <SolidColorBrush x:Key="PrimaryBlue" Color="#4E73DF"/>
        <SolidColorBrush x:Key="LightSelectionBlue" Color="#EBF0FF"/>

        <Style x:Key="CenterTextStyle" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="TextAlignment" Value="Center"/>
        </Style>

        <Style x:Key="ModernRowStyle" TargetType="DataGridRow">
            <Setter Property="Background" Value="Transparent"/>
            <Style.Resources>
                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#EBF0FF"/>
                <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="#EBF0FF"/>
                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#4E73DF"/>
                <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}" Color="#4E73DF"/>
            </Style.Resources>
        </Style>

        <Style x:Key="MenuStyle" TargetType="ListBoxItem">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="bd" Padding="15,12" Background="Transparent" Margin="10,2">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource PrimaryBlue}"/>
                                <Setter TargetName="bd" Property="CornerRadius" Value="8"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#2A2E33"/>
                                <Setter TargetName="bd" Property="CornerRadius" Value="8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="#F8F9FC">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0" Background="{StaticResource SidebarBrush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="80"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="🚘" Foreground="White" Margin="0,-10,10,0" FontSize="29"/>
                <TextBlock Text="GARA AUTO" Foreground="White" FontSize="20" FontWeight="Bold"/>
            </StackPanel>

            <ListBox x:Name="MenuSideBar" Grid.Row="1" Background="Transparent" BorderThickness="0" Margin="0,10" SelectionChanged="MenuSideBar_SelectionChanged">
                <ListBoxItem Style="{StaticResource MenuStyle}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="📊" Foreground="White"/>
                        <TextBlock Text="Dashboard" Foreground="White" Margin="15,0,0,0"/>
                    </StackPanel>
                </ListBoxItem>
                <ListBoxItem Style="{StaticResource MenuStyle}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="👥" Foreground="White"/>
                        <TextBlock Text="Quản lý khách hàng" Foreground="White" Margin="15,0,0,0"/>
                    </StackPanel>
                </ListBoxItem>
                <ListBoxItem Style="{StaticResource MenuStyle}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🚘" Foreground="White"/>
                        <TextBlock Text="Xe" Foreground="White" Margin="15,0,0,0"/>
                    </StackPanel>
                </ListBoxItem>
                <ListBoxItem Style="{StaticResource MenuStyle}" IsSelected="True">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🛠️" Foreground="White"/>
                        <TextBlock Text="Dịch vụ" Foreground="White" Margin="15,0,0,0"/>
                    </StackPanel>
                </ListBoxItem>
                <ListBoxItem Style="{StaticResource MenuStyle}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="📦" Foreground="White"/>
                        <TextBlock Text="Phụ tùng" Foreground="White" Margin="15,0,0,0"/>
                    </StackPanel>
                </ListBoxItem>
                <ListBoxItem Style="{StaticResource MenuStyle}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="📅" Foreground="White"/>
                        <TextBlock Text="Đặt lịch" Foreground="White" Margin="15,0,0,0"/>
                    </StackPanel>
                </ListBoxItem>
            </ListBox>

            <Border Grid.Row="2" Background="#2A2E33" Padding="15" CornerRadius="10" Margin="10,0,10,20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Ellipse Width="40" Height="40" Stroke="White" StrokeThickness="1">
                        <Ellipse.Fill>
                            <ImageBrush ImageSource="/Images/account.png" Stretch="UniformToFill"/>
                        </Ellipse.Fill>
                    </Ellipse>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="10,0">
                        <TextBlock Text="Dmanhz" Foreground="White" FontWeight="SemiBold" FontSize="13"/>
                        <TextBlock Text="Quản lý" Foreground="#9DA1A7" FontSize="11"/>
                    </StackPanel>
                    <Button Grid.Column="2" Background="Transparent" BorderThickness="0" Foreground="White" Cursor="Hand" Content="⋮" FontSize="20" VerticalAlignment="Center">
                        <Button.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Cài đặt tài khoản"/>
                                <MenuItem x:Name="btnLogout" Header="Đăng xuất" Foreground="Red" Click="btnLogout_Click"/>
                            </ContextMenu>
                        </Button.ContextMenu>
                    </Button>
                </Grid>
            </Border>
        </Grid>

        <Grid Grid.Column="1" Margin="25">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,20">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Quản lý dịch vụ" FontSize="26" FontWeight="Bold" Foreground="#333"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button Background="Transparent" BorderThickness="0" Margin="0,0,15,0" Cursor="Hand">
                        <Image Source="/Images/bell.png" Width="22" Height="22"/>
                    </Button>
                    <Button Background="Transparent" BorderThickness="0" Cursor="Hand">
                        <Image Source="/Images/settings_profile1.png" Width="22" Height="22"/>
                    </Button>
                </StackPanel>
            </Grid>

            <Grid Grid.Row="1" Margin="0,0,0,20">

                <Border Background="White" CornerRadius="8" BorderBrush="#E3E6F0" BorderThickness="1" HorizontalAlignment="Left" Width="350" Height="40">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="40"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="🔍" VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="#B7B9CC" FontSize="14"/>
                        <TextBlock Grid.Column="1" Text="Tìm kiếm dịch vụ..." Foreground="#B7B9CC" VerticalAlignment="Center" Margin="5,0" IsHitTestVisible="False"
                                   Visibility="{Binding Text.IsEmpty, ElementName=txtSearch, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                        <TextBox x:Name="txtSearch" Grid.Column="1" Background="Transparent" BorderThickness="0" VerticalContentAlignment="Center" Padding="5,0" TextChanged="TxtSearch_TextChanged"/>
                    </Grid>
                </Border>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="btnExportExcel" Content="📥 Xuất Excel" Background="#1CC88A" Foreground="White" 
            Padding="15,0" Height="40" FontWeight="Bold" BorderThickness="0" Margin="0,0,10,0" Cursor="Hand">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="8"/>
                            </Style>
                        </Button.Resources>
                    </Button>

                    <Button x:Name="btnGoToReception" Content="🚗 Tiếp nhận xe" Click="btnGoToReception_Click" 
            Background="#36B9CC" Foreground="White" Padding="15,0" Height="40" 
            FontWeight="Bold" BorderThickness="0" Margin="0,0,10,0" Cursor="Hand">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="8"/>
                            </Style>
                        </Button.Resources>
                    </Button>

                    <Button x:Name="btnAddService" Content="+ Thêm dịch vụ" Click="btnAddService_Click" 
            Background="{StaticResource PrimaryBlue}" Foreground="White" 
            Padding="20,0" Height="40" FontWeight="Bold" BorderThickness="0" Cursor="Hand">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="8"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </StackPanel>
            </Grid>

            <Border Grid.Row="2" Background="White" CornerRadius="12" BorderBrush="#E3E6F0" BorderThickness="1" Padding="10">
                <DataGrid x:Name="dgServices" AutoGenerateColumns="False" CanUserAddRows="False" 
                      RowStyle="{StaticResource ModernRowStyle}" SelectionMode="Single"
                      HeadersVisibility="Column" GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#F1F1F1"
                      Background="Transparent" BorderThickness="0" RowHeight="55" 
                      HorizontalScrollBarVisibility="Auto">

                    <DataGrid.Resources>
                        <Style x:Key="LeftTextStyle" TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Left"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                            <Setter Property="Margin" Value="10,0,10,0"/>
                            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                            <Setter Property="ToolTip" Value="{Binding Text, RelativeSource={RelativeSource Self}}"/>
                        </Style>
                    </DataGrid.Resources>

                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Foreground" Value="#4E73DF"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                            <Setter Property="Padding" Value="10"/>
                            <Setter Property="HorizontalContentAlignment" Value="Center"/>
                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                            <Setter Property="BorderBrush" Value="#F1F1F1"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="STT" Binding="{Binding ServiceID}" Width="80" ElementStyle="{StaticResource CenterTextStyle}"/>

                        <DataGridTextColumn Header="Tên Dịch Vụ" Binding="{Binding ServiceName}" Width="*" ElementStyle="{StaticResource CenterTextStyle}"/>

                        <DataGridTextColumn Header="Giá Tiền (VNĐ)" Binding="{Binding Price, StringFormat={}{0:N0}}" Width="200" ElementStyle="{StaticResource CenterTextStyle}"/>

                        <DataGridTemplateColumn Header="Hành động" Width="100">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <Button x:Name="btnEdit" Background="Transparent" BorderThickness="0" Cursor="Hand" Margin="8,0" Click="btnEdit_Click">
                                            <Image Source="/Images/edit_icon.png" Width="18" Height="18" RenderOptions.BitmapScalingMode="HighQuality"/>
                                        </Button>
                                        <Button x:Name="btnDelete" Background="Transparent" BorderThickness="0" Cursor="Hand" Margin="8,0" Click="btnDelete_Click">
                                            <Image Source="/Images/delete_icon.png" Width="18" Height="18" RenderOptions.BitmapScalingMode="HighQuality"/>
                                        </Button>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Grid>
    </Grid>
</Window>