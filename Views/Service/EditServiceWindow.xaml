<Window x:Class="test2.Views.Service.EditServiceWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Chỉnh sửa dịch vụ" Height="300" Width="380" WindowStyle="None" 
        AllowsTransparency="True" Background="Transparent" WindowStartupLocation="CenterOwner">
    <Border Background="White" CornerRadius="15" BorderBrush="#4E73DF" BorderThickness="1" Margin="10">
        <Border.Effect>
            <DropShadowEffect BlurRadius="15" Direction="0" ShadowDepth="0" Opacity="0.1"/>
        </Border.Effect>
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Text="CẬP NHẬT DỊCH VỤ" FontWeight="Bold" Foreground="#4E73DF" HorizontalAlignment="Center" FontSize="20"/>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,15">
                <StackPanel>
                    <TextBlock Text="Tên dịch vụ" Margin="0,5" Foreground="#666"/>
                    <TextBox x:Name="txtEditTenDichVu" Height="30" VerticalContentAlignment="Center" Padding="5,0" Margin="0,0,0,10"/>

                    <TextBlock Text="Giá tiền (VNĐ)" Margin="0,5" Foreground="#666"/>
                    <TextBox x:Name="txtEditGiaTien" Height="30" VerticalContentAlignment="Center" Padding="5,0" Margin="0,0,0,10"/>
                </StackPanel>
            </ScrollViewer>

            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Hủy" Width="70" Height="30" Margin="0,0,10,0" Click="Cancel_Click" Background="#F1F1F1" BorderThickness="0">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="5"/>
                        </Style>
                    </Button.Resources>
                </Button>
                <Button Content="Lưu" Width="70" Height="30" Background="#4E73DF" Foreground="White" BorderThickness="0" Click="Save_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="5"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</Window>