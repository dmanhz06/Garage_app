<Window x:Class="test2.Views.Model_Box.EditCustomerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Chỉnh sửa khách hàng" Height="400" Width="350" WindowStyle="None" 
        AllowsTransparency="True" Background="Transparent" WindowStartupLocation="CenterOwner">
    <Border Background="White" CornerRadius="15" BorderBrush="#4E73DF" BorderThickness="1">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Text="CẬP NHẬT THÔNG TIN KH " FontWeight="Bold" Foreground="#4E73DF" HorizontalAlignment="Center" FontSize="22"/>

            <StackPanel Grid.Row="1" Margin="0,15">
                <TextBlock Text="Họ và tên" Margin="0,5" Foreground="#666"/>
                <TextBox x:Name="txtEditName" Height="30" VerticalContentAlignment="Center" Padding="5,0" Margin="0,0,0,10"/>

                <TextBlock Text="Số điện thoại" Margin="0,5" Foreground="#666"/>
                <TextBox x:Name="txtEditPhone" Height="30" VerticalContentAlignment="Center" Padding="5,0" Margin="0,0,0,10"/>

                <TextBlock Text="Địa chỉ" Margin="0,5" Foreground="#666"/>
                <TextBox x:Name="txtEditAddress" Height="30" VerticalContentAlignment="Center" Padding="5,0"/>
            </StackPanel>

            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Hủy" Width="70" Height="30" Margin="0,0,10,0" Click="Cancel_Click"/>
                <Button Content="Lưu" Width="70" Height="30" Background="#4E73DF" Foreground="White" Click="Save_Click"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>