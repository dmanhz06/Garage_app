<Window x:Class="test2.Views.Customer.AddCustomerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Thêm Khách Hàng Mới" Height="500" Width="450"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent">

    <Border Background="White" CornerRadius="15" BorderBrush="#E3E6F0" BorderThickness="1">
        <Grid Margin="25">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Grid.Row="0" Margin="0,0,0,20">
                <TextBlock Text="Thêm Khách Hàng" FontSize="22" FontWeight="Bold" Foreground="#4E73DF"/>
                <TextBlock Text="Vui lòng điền đầy đủ thông tin bên dưới" FontSize="12" Foreground="#858796" Margin="0,5,0,0"/>
            </StackPanel>

            <!-- Form -->
            <StackPanel Grid.Row="1">
                <TextBlock Text="Họ và tên" FontWeight="SemiBold" Margin="0,10,0,5" Foreground="#333"/>
                <TextBox x:Name="txtName" Height="35" VerticalContentAlignment="Center" Padding="10,0" Margin="0,0,0,10">
                    <TextBox.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="5"/>
                        </Style>
                    </TextBox.Resources>
                </TextBox>

                <TextBlock Text="Số điện thoại" FontWeight="SemiBold" Margin="0,10,0,5" Foreground="#333"/>
                <TextBox x:Name="txtPhone" Height="35" VerticalContentAlignment="Center" Padding="10,0" Margin="0,0,0,10">
                    <TextBox.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="5"/>
                        </Style>
                    </TextBox.Resources>
                </TextBox>

                <TextBlock Text="Địa chỉ" FontWeight="SemiBold" Margin="0,10,0,5" Foreground="#333"/>
                <TextBox x:Name="txtAddress" Height="35" VerticalContentAlignment="Center" Padding="10,0" Margin="0,0,0,10">
                    <TextBox.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="5"/>
                        </Style>
                    </TextBox.Resources>
                </TextBox>

                <TextBlock Text="Email" FontWeight="SemiBold" Margin="0,10,0,5" Foreground="#333"/>
                <TextBox x:Name="txtEmail" Height="35" VerticalContentAlignment="Center" Padding="10,0" Margin="0,0,0,10">
                    <TextBox.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="5"/>
                        </Style>
                    </TextBox.Resources>
                </TextBox>
            </StackPanel>

            <!-- Buttons -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                <Button Content="Hủy bỏ" Click="btnCancel_Click" Width="100" Height="35" Background="#F8F9FC" Foreground="#333" BorderBrush="#D1D3E2" Margin="0,0,10,0">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="5"/>
                        </Style>
                    </Button.Resources>
                </Button>
                <Button Content="Lưu thông tin" Click="btnSave_Click" Width="120" Height="35" Background="#4E73DF" Foreground="White" BorderThickness="0" FontWeight="Bold">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="5"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</Window>