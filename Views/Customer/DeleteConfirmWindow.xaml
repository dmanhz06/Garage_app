<Window x:Class="test2.Views.Model_Box.DeleteConfirmWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Xác nhận xóa" Height="220" Width="400" WindowStyle="None" 
        AllowsTransparency="True" Background="Transparent" WindowStartupLocation="CenterOwner">

    <Border Background="White" CornerRadius="15" Margin="10">
        <Border.Effect>
            <DropShadowEffect BlurRadius="15" Direction="0" ShadowDepth="0" Opacity="0.1"/>
        </Border.Effect>

        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Text="🗑️ Xác nhận xóa" FontSize="18" FontWeight="Bold" Foreground="#FFE5342D"/>

            <TextBlock x:Name="txtMessage" Grid.Row="1" Text="Bạn có chắc chắn muốn xóa khách hàng này không?" 
                       TextWrapping="Wrap" VerticalAlignment="Center" Foreground="#666" FontSize="14"/>

            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Hủy" Width="80" Height="35" Background="#F1F1F1" BorderThickness="0" Cursor="Hand" Click="Cancel_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="8"/>
                        </Style>
                    </Button.Resources>
                </Button>
                <Button Content="Xác nhận xóa" Width="100" Height="35" Margin="10,0,0,0" 
                        Background="#FFDF4E4E" Foreground="White" FontWeight="Bold" BorderThickness="0" Cursor="Hand" Click="Confirm_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="8"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</Window>