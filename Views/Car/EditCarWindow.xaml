<Window x:Class="test2.Views.Model_Box.EditCarWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Chỉnh sửa thông tin xe" Height="450" Width="380" WindowStyle="None" 
        AllowsTransparency="True" Background="Transparent" WindowStartupLocation="CenterOwner">
    <Border Background="White" CornerRadius="15" BorderBrush="#4E73DF" BorderThickness="1">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Text="CẬP NHẬT THÔNG TIN XE" FontWeight="Bold" Foreground="#4E73DF" HorizontalAlignment="Center" FontSize="20"/>

            <StackPanel Grid.Row="1" Margin="0,15">
                <TextBlock Text="Biển số" Margin="0,5" Foreground="#666"/>
                <TextBox x:Name="txtEditBienSo" Height="35" VerticalContentAlignment="Center" Padding="10,0" Margin="0,0,0,10"/>

                <TextBlock Text="Hãng xe" Margin="0,5" Foreground="#666"/>
                <TextBox x:Name="txtEditHang" Height="35" VerticalContentAlignment="Center" Padding="10,0" Margin="0,0,0,10"/>

                <TextBlock Text="Dòng xe" Margin="0,5" Foreground="#666"/>
                <TextBox x:Name="txtEditDong" Height="35" VerticalContentAlignment="Center" Padding="10,0" Margin="0,0,0,10"/>

                <TextBlock Text="Chủ xe" Margin="0,5" Foreground="#666"/>
                <TextBox x:Name="txtEditChuXe" Height="35" VerticalContentAlignment="Center" Padding="10,0"/>
            </StackPanel>

            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                <Button Content="Hủy" Width="80" Height="35" Margin="0,0,10,0" Click="Cancel_Click" Background="#F1F1F1" BorderThickness="0"/>
                <Button Content="Cập nhật" Width="100" Height="35" Background="#4E73DF" Foreground="White" FontWeight="Bold" Click="Save_Click" BorderThickness="0"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>